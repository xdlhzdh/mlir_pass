import os

_lit_dir = os.path.dirname(os.path.abspath(__file__))
_lit_source_dir = os.path.join("@CMAKE_CURRENT_SOURCE_DIR@", "lit")

config.ai_compiler_demo = "@CMAKE_BINARY_DIR@/tools/ai-compiler-demo/ai-compiler-demo"
config.substitutions.append(("%ai-compiler-demo", config.ai_compiler_demo))

# Load suite settings from source; then pin roots to the build lit dir (not test/lit/).
lit_config.load_config(config, os.path.join(_lit_source_dir, "lit.cfg.py"))

config.test_source_root = _lit_dir
config.test_exec_root = _lit_dir
